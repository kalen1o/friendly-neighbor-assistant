# ── Auth ──
JWT_SECRET=change-me-in-production-use-a-random-string
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
# Set true in production (HTTPS)
COOKIE_SECURE=false
# Leave empty for localhost, set to your domain in production
COOKIE_DOMAIN=
# "development" or "production"
ENVIRONMENT=development

# ── Logging ──
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── AI Provider ──
# "anthropic" or "openai"
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# Leave empty for OpenAI. Set for compatible providers:
#   Z.ai:       https://api.z.ai/api/paas/v4
#   OpenRouter:  https://openrouter.ai/api/v1
#   Ollama:      http://localhost:11434/v1
OPENAI_BASE_URL=
# Model name (e.g. gpt-4o, glm-5.1, deepseek-chat)
OPENAI_MODEL=gpt-4o

# ── Project Models ──
# Comma-separated list of models available to all users (uses project API keys above)
# Format: provider:model_id[@base_url]  (provider = openai, anthropic, or openai_compatible)
# If no @base_url, uses OPENAI_BASE_URL for openai providers, none for anthropic
# If empty, a single default is derived from AI_PROVIDER + OPENAI_MODEL
# Examples:
#   PROJECT_MODELS=openai:gpt-4o,openai:gpt-4o-mini,anthropic:claude-sonnet-4-20250514
#   PROJECT_MODELS=openai:glm-5.1@https://api.z.ai/api/coding/paas/v4,openai:gpt-4o
PROJECT_MODELS=

# ── Custom Models (user API keys) ──
# Fernet encryption key for storing user API keys in the database
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate witj: openssl rand -base64 32
# If empty, users cannot add custom models (project models still work)
ENCRYPTION_KEY=

# ── Admin ──
# Comma-separated emails that get admin role on registration
# These admins cannot be demoted or deleted from the dashboard
ADMIN_EMAILS=

# ── Agent ──
# Max LLM <-> tool call rounds per message (default 5)
MAX_TOOL_ROUNDS=5

# ── OAuth (optional — buttons hidden if not set) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Where to redirect after OAuth login
FRONTEND_URL=http://localhost:3000

# ── RAG ──
RAG_HYBRID_SEARCH_ENABLED=true
RAG_FULLTEXT_WEIGHT=0.4
RAG_RERANK_ENABLED=false
COHERE_API_KEY=
RAG_TOP_K=5
RAG_MIN_SCORE=0.5
RAG_RERANK_TOP_N=20
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_CHUNK_STRATEGY=semantic

# ── Webhooks ──
# Max webhook integrations per user
MAX_WEBHOOKS_PER_USER=10

# ── Embeddings ──
EMBEDDING_MODEL=text-embedding-3-small
# Leave empty to use OPENAI_API_KEY
EMBEDDING_API_KEY=
# Leave empty to use OPENAI_BASE_URL
EMBEDDING_BASE_URL=

# ── Vision (used when images are attached) ──
# Model name for vision tasks
VISION_MODEL=GLM-4.5V
# Leave empty to use OPENAI_API_KEY
VISION_API_KEY=
# Leave empty to use OPENAI_BASE_URL
VISION_BASE_URL=

# ── File Uploads ──
# Local directory for uploaded files
UPLOAD_DIR=uploads
# Max file size in MB
MAX_UPLOAD_SIZE_MB=10

# ── Database ──
POSTGRES_USER=friendly
POSTGRES_PASSWORD=friendly_secret
POSTGRES_DB=friendly_neighbor
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://friendly:friendly_secret@db:5432/friendly_neighbor

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── Web Search — DuckDuckGo requires no API key ──

# ── Ports ──
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
