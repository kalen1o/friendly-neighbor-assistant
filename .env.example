# ── AI Provider ──
AI_PROVIDER=anthropic                       # "anthropic" or "openai"
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=                            # Leave empty for OpenAI. Set for compatible providers:
                                            #   Z.ai:       https://api.z.ai/api/paas/v4
                                            #   OpenRouter:  https://openrouter.ai/api/v1
                                            #   Ollama:      http://localhost:11434/v1
OPENAI_MODEL=gpt-4o                        # Model name (e.g. gpt-4o, glm-5, deepseek-chat)

# ── Embeddings ──
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=                             # Leave empty to use OPENAI_API_KEY
EMBEDDING_BASE_URL=                            # Leave empty to use OPENAI_BASE_URL

# ── Database ──
POSTGRES_USER=friendly
POSTGRES_PASSWORD=friendly_secret
POSTGRES_DB=friendly_neighbor
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://friendly:friendly_secret@db:5432/friendly_neighbor

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ── Web Search — DuckDuckGo requires no API key ──

# ── Ports ──
BACKEND_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
